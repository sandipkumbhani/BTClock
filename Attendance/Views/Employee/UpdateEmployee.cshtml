@model Attendance.Domain.Models.EmployeeDto
@using System.Security.Claims
@using Attendance.Domain.Models
@{
	Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<head>
	<link href="~/css/calender.css" rel="stylesheet" />
</head>
<body>
	<div class="main-inner container-fluid">
		<div class="col-12">
			<div class="page-title-box" style="margin-top:20px;">
				<h1 class="page-title">Edit Employee</h1>
			</div>
		</div>
		<div class="col-12">
			<div class="card com-profile-info">
				<form class="form" id="userForm" method="post" action="@Url.Action("UpdateEmployee", "Employee")">
					<div class="top-details">
						<h2 class="page-form-title">Edit Employee</h2>
						<div class="file-input">
						</div>
						<div class="">
							<div class="item-input" style="display:none;">
								<label for="EmployeeId" class="form-label col-form-label required fw-semibold fs-6; form-label">Name</label>
								<input type="text" class="form-control userinput" id="EmployeeId" value="@Model.EmployeeId" name="EmployeeId" required placeholder="Enter Name" style="width:359.46px; height:48px;">
								@* <span asp-validation-for="Name" class="text-danger"></span> *@
							</div>
						</div>
						<div class="">
							<div class="item-input">
								<label for="name" class="form-label col-form-label required fw-semibold fs-6; form-label">Name</label>
								<input type="text" class="form-control userinput" id="name" value="@Model.Name" name="name" required placeholder="Enter Name" style="width:359.46px; height:48px;">
								@* <span asp-validation-for="Name" class="text-danger"></span> *@
							</div>
						</div>
						<div class="">
							<div class="item-input">
								<label for="email" class="form-label col-form-label required fw-semibold fs-6; form-label">Email</label>
								<input type="email" class="form-control userinput" id="email" value="@Model.Email" name="email" required placeholder="Enter Email" style="width:359.46px; height:48px;">
								@* <span asp-validation-for="Email" class="text-danger"></span> *@
							</div>
						</div>
						<div class="">
							<div class="item-input">
								<label for="mobileNo" class="form-label col-form-label required fw-semibold fs-6;form-label">Mobile No.</label>
								<input type="tel" class="form-control userinput" id="mobileNo" value="@Model.MobileNo" name="mobileNo" required placeholder="Enter Mobile No" style="width:359.46px; height:48px;">
								@* <span asp-validation-for="MobileNo" class="text-danger"></span> *@

							</div>
						</div>
						@* <div class="">
							<div class="item-input">
								<label for="password" class="form-label col-form-label required fw-semibold fs-6;form-label">Password</label>
								<input type="password" class="form-control userinput" id="password" name="password" placeholder="Enter Password" required style="width:359.46px; height:48px;">
								@* <span asp-validation-for="Password" class="text-danger"></span> 
							</div>
						</div> *@
						<div class="col-xl-4 col-lg-6">
							<div class="item-input">
								<label for="Department" class="form-label col-form-label required fw-semibold fs-6; form-label">Department</label>
								<select class="select2-custom form-control select2-hidden-accessible; form-select" style="width: 100%;" data-placeholder="Select Department" id="DepartmentId" name="DepartmentId">
									<option selected accesskey="#0" value="@Model.DepartmentId">@Model.Department!.Name</option>
									@foreach (var department in ViewBag.Department)
									{
										<option value="@department.Id">@department.Name</option>
									}
								</select>
							</div>
							<div class="item-input">
								<label for="DesignationId" class="form-label col-form-label required fw-semibold fs-6; form-label">Designation</label>
								<select class="select2-custom form-control select2-hidden-accessible; form-select" style="width: 100%;" data-placeholder="Select Designation" id="DesignationId" name="DesignationId">

									<option selected accesskey="#0" value="@Model.DesignationId">@Model.Designation!.DesignationName</option>
									@foreach (var designation in ViewBag.Designation)
									{
										<option value="@designation.DesignationId">@designation.DesignationName</option>
									}

								</select>
							</div>
							<div class="item-input">
								<label for="ManagerId" class="form-label col-form-label required fw-semibold fs-6; form-label">Manager</label>
								<select class="select2-custom form-control select2-hidden-accessible; form-select" style="width: 100%;" data-placeholder="Select Manager" id="ManagerId" name="ManagerId">
									@if (Model.ManagerId != null && Model.ManagerId != 0)
									{
										<option selected  value="@Model.ManagerId">
											@foreach (var manager in ViewBag.Manager)
											{
												ViewBag.ManagerName = ((List<EmployeeDto>)ViewBag.Manager).Find(m => m.EmployeeId == Model.ManagerId)?.Name;
											}
											@ViewBag.ManagerName
										</option>
									}
									else
									{
										<option value="0" disabled selected>Select Manager</option>
									}
									@foreach (var manager in ViewBag.Manager)
									{
										<option value="@manager.EmployeeId">@manager.Name</option>
									}
								</select>
							</div>
							<div class="item-input">
								<label for="DateOfJoining" class="form-label col-form-label required fw-semibold fs-6; form-label">Date Of Joining</label><br />
								<input type="text" data-provide="datepicker" class="form-control userinput date" id="datepicker" name="DateOfJoining" value="@Model.DateOfJoining" placeholder="Select a Date" style="width:370px;	">
							</div>
							<div class="item-input">
								<label for="DateofLeaving" class="form-label col-form-label required fw-semibold fs-6; form-label">Date Of Leaveing</label><br />
								<input type="text" data-provide="datepicker" class="form-control userinput date" id="datepicker" value="@Model.DateofLeaving" name="DateofLeaving" placeholder="Select a Date" style="width:370px;	">

							</div>
							 <div class="col-xl-6">
								@if (ViewBag.Message != null)
								{
										<div class="us,ermsg" id="temporaryMessage">
										<span style="color:#00af00;font-weight:600;">@ViewBag.Message</span>
										</div>
								}
								else
								{
										<div class="usermsg" id="temporaryMessage">
										<span style="color:#d21313;font-weight:600;"> @ViewBag.ErrorMessage </span>
										</div>
								}
							</div> 
						</div>
					</div>
					<div class="button-main">
						<button type="submit" class="btn btn-primary me-2" style="width:95px;height:38px;background-color: #0466c8;">Update</button>
						@*<button type="submit" formaction="@Url.Action("MasterView", "MenuMaster")" class="btn btn-primary me-2" style="width:95px;height:38px;background-color: #0466c8;">View</button>*@
						<a class="btn btn-primary me-2" href="/Employee/ViewEmployee" style=" width: 95px;height: 38px;background-color: #0466c8;">Back</a>
					</div>

				</form>
			</div>
		</div>
	</div>
</body>
@section Scripts {
	<script src="~/js/calender.js"></script>
	<script src="~/js/msgtimeout.js"></script>
} 
