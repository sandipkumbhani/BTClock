@model IEnumerable<Attendance.Domain.Models.EmployeeDto>
@using System.Security.Claims
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<link href="~/css/employee.css" rel="stylesheet" />
<div class="app-content px-lg-3">
    <div class="app-container container-fluid">
      
        <div id="employeelist">
            <div class="card com-profile-info">
                <div class="row mt-3">
                </div>
             
                <div class="table-top-header">
                    <h4>List of Employee</h4>

                    <div class="d-flex gap-2">
                        <div class="table-search-box">
                            <input type="text" id="customcorporateSearch" class="form-control form-control-sm" placeholder="Search...">
                            <button type="submit"><i class="ri-search-line"></i></button>
                        </div>

                        <div id="exportcorporateButtons" class="btn-group" role="group" style="display:none;"></div>
                    </div>
                </div>
                <div class="table-responsive">
                    <div class="col-xl-6" style="margin-left:30px;">
                        <div class="col-xl-6">
                            @if (TempData["Message"] != null)
                            {
                                <div class="usermsg" id="temporaryMessage">
                                    <span style="color:#00af00;font-weight:600;">@TempData["Message"]</span>
                                </div>
                            }
                            else
                            {
                                <div class="usermsg" id="temporaryMessage">
                                    <span style="color:#d21313;font-weight:600;"> @TempData["errormsg"]</span>
                                </div>
                            }
                        </div>
                    </div>
                    <table id="corporateTable" class="table dt-responsive nowrap w-100">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Mobile no</th>
                                <th>Designation</th>
                                <th>Department</th>
                                <th>Manager</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                    <div id="dataLoader" class=" justify-content-center" style="display:none; margin-left: 598px;">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
                <!-- Bottom Area -->
                <div class="datatable-footer-bottom">
                    <div class="totle-left">
                        <span id="totalRemindersCorporate">Total List: 3</span>
                    </div>
                    <div id="customcorporatePagination" class="dataTables_paginate paging_simple_numbers"></div>
                    <div class="show-page">
                        <span>Show per page:</span>
                        <select id="pageLength" class="form-select">
                            <option value="5">5 </option>
                            <option value="10" selected>10 </option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="-1">All</option>
                        </select>
                    </div>
                </div>
                <div class="button-main">
                    @* <input class=" card-link" type="button" value="Add" style="width:95px;height:38px; border:thick; text-box-edge: cap alphabetic; text-box-trim: trim-start;" onclick="location.href='@Url.Action("MenuMaster", "MenuMaster", new { })'" />*@
                    <a class="btn btn-primary me-2" href="/Employee/Employee" style=" width: 95px;height: 38px;background-color: #0466c8;">Add</a>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        var url = '@Url.Action("UpdateEmployee", "Employee")' + '?employeeId=';
         var deleteurl = '@Url.Action("DeleteEmployee", "Employee")' + '?id=';
    </script>
	<script src="~/js/employeeview.js"></script>
    <script src="~/js/msgtimeout.js"></script>
}

