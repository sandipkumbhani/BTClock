@model Attendance.Domain.Models.LeaveAssignmentDto
@using System.Security.Claims
@using Attendance.Domain.Models
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}


<div class="main-inner container-fluid">

    <div class="col-12">
        <div class="page-title-box" style="margin-top:20px;">
            <h1 class="page-title">Leave Assignment</h1>
        </div>
    </div>
    <div class="col-12">
        <div class="card com-profile-info">
            <form class="form" id="userForm" method="post" asp-action="LeaveAssignment" asp-controller="LeaveAssignment">
                <div class="top-details">
                    <h2 class="page-form-title">Leave Assignment</h2>
                    <div class="">
                        <div class="item-input">
                            <label for="LeaveMasterId" class="form-label col-form-label required fw-semibold fs-6">Leave Type</label>
                            <select class="select2-custom form-control select2-hidden-accessible form-select" id="LeaveMasterId" name="LeaveMasterId" style="width:359.46px; height:48px;" required>
                                <option value="" disabled selected>Select Leave Type</option>
                                @foreach (var leave in ViewBag.leaveMasters)
                                {
                                    <option value="@leave.LeaveMasterId">@leave.LeaveType</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="">
                        <div class="item-input">
                            <label for="DepartmentId" class="form-label col-form-label required fw-semibold fs-6">Department</label>
                            <select class="select2-custom form-control select2-hidden-accessible form-select" id="DepartmentId" name="DepartmentId" style="width:359.46px; height:48px;" required>
                                <option value="" disabled selected>Select Department</option>
                                @foreach (var departments in ViewBag.departments)
                                {
                                    <option value="@departments.Id">@departments.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="">
                        <div class="item-input">
                            <label for="TotalAllocatedLeaves" class="form-label col-form-label required fw-semibold fs-6; form-label">TotalAllocatedLeaves</label>
                            <input type="text" class="form-control userinput" id="TotalAllocatedLeaves" name="TotalAllocatedLeaves" required placeholder="Enter Allocated Leaves" style="width:359.46px; height:48px;">
                        </div>
                    </div>
                    <div class="col-xl-12 col-lg-6">
                        <div class="item-input">
                            <label for="PaidAllocatedLeaves" class="form-label col-form-label required fw-semibold fs-6; form-label">PaidAllocatedLeaves</label>
                            <input type="text" class="form-control userinput" id="PaidAllocatedLeaves" name="PaidAllocatedLeaves" required placeholder="Enter PaidAllocatedLeaves" style="width:359.46px; height:48px;">
                        </div>
                    </div>
                </div>
                <div class="col-xl-6" style="margin-left:30px;">
                    @if (ViewBag.msg != null)
                    {
                        <div class="usermsg" id="temporaryMessage">
                            <span style="color:#00af00;font-weight:600;">@ViewBag.msg</span>
                        </div>
                    }
                    else
                    {
                        <div class="usermsg" id="temporaryMessage">
                            <span style="color:#d21313;font-weight:600;"> @ViewBag.errormsg</span>
                        </div>
                    }
                </div>
                <div class="button-main">
                    <button type="submit" class="btn btn-primary me-2" style="width:95px;height:38px;background-color: #0466c8;">Save</button>
                    @*<button type="submit" formaction="@Url.Action("MasterView", "MenuMaster")" class="btn btn-primary me-2" style="width:95px;height:38px;background-color: #0466c8;">View</button>*@
                    <a class="btn btn-primary me-2" href="/LeaveAssignment/LeaveAssignmentView" style=" width: 95px;height: 38px;background-color: #0466c8;">View</a>
                </div>
            </form>
        </div>
    </div>
</div>



