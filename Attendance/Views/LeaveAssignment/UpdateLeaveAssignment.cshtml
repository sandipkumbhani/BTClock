@model Attendance.Domain.Models.LeaveAssignmentDto

@using System.Security.Claims
@using Attendance.Domain.Utility
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}


<div class="main-inner container-fluid">
    <div class="col-12">
        <div class="page-title-box" style="margin-top:20px;">
            <h1 class="page-title">Update Leave Assignment</h1>
        </div>
    </div>
    <div class="col-12">
        <div class="card com-profile-info">
            <form class="form" id="updateForm" method="post" enctype="multipart/form-data" asp-action="UpdateLeaveAssignment" asp-controller="LeaveAssignment">
                <input type="hidden" asp-for="LeaveAssignmentId" />
                <div class="top-details">
                    <h2 class="page-form-title">Leave Assignment Update</h2>
                    <div class="">
                        <div class="item-input">
                            <label for="LeaveMasterId" class="form-label col-form-label required fw-semibold fs-6">Leave Type</label>
                            <select class="select2-custom form-control form-select" id="LeaveMasterId" name="LeaveMasterId" style="width:359.46px; height:48px;" required>

                                @foreach (var leave in ViewBag.leaveMasters)
                                {
                                    if (leave.LeaveMasterId == Model.leavemasterId)
                                    {
                                        <option value="@leave.LeaveMasterId" selected>
                                            @leave.LeaveType
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@leave.LeaveMasterId">
                                            @leave.LeaveType
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="">
                        <div class="item-input">
                            <label for="DepartmentId" class="form-label col-form-label required fw-semibold fs-6">Leave Type</label>
                            <select class="select2-custom form-control form-select" id="DepartmentId" name="DepartmentId" style="width:359.46px; height:48px;" required>

                                @foreach (var depts in ViewBag.departments)
                                {
                                    if (depts.Id == Model.DepartmentId)
                                    {
                                        <option value="@depts.Id" selected>
                                            @depts.Name
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@depts.Id">
                                            @depts.Name
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="">
                        <div class="item-input">
                            <label for="TotalAllocatedLeaves" class="form-label col-form-label required fw-semibold fs-6; form-label">TotalAllocatedLeaves</label>
                            <input type="text" class="form-control userinput" id="TotalAllocatedLeaves" name="TotalAllocatedLeaves" value="@Model.TotalAllocatedLeaves" required placeholder="Enter Allocated Leaves" style="width:359.46px; height:48px;">
                        </div>
                    </div>
                    <div class="">
                        <div class="item-input">
                            <label for="PaidAllocatedLeaves" class="form-label col-form-label required fw-semibold fs-6; form-label">PaidAllocatedLeaves</label>
                            <input type="text" class="form-control userinput" id="PaidAllocatedLeaves" name="PaidAllocatedLeaves" value="@Model.PaidAllocatedLeaves" required placeholder="Enter Allocated Leaves" style="width:359.46px; height:48px;">
                        </div>
                    </div>
                </div>

                <div class="col-xl-6" style="margin-left:30px;">
                    @if (ViewBag.msg != null)
                    {
                        <div class="usermsg" id="temporaryMessage">
                            <span style="color:#00af00;font-weight:600;">@ViewBag.msg</span>
                        </div>
                    }
                    else if (ViewBag.errormsg != null)
                    {
                        <div class="usermsg" id="temporaryMessage">
                            <span style="color:#d21313;font-weight:600;">@ViewBag.errormsg</span>
                        </div>
                    }
                </div>

                <div class="button-main">
                    <button type="submit" class="btn btn-primary me-2" style="width:95px;height:38px;background-color: #0466c8;">Update</button>
                    <a class="btn btn-secondary me-2" href="/LeaveAssignment/LeaveAssignmentView" style="width:95px;height:38px;background-color: #0466c8;">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>
