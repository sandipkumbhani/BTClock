@model Attendance.Domain.Models.LeaveTransactionDto

@using System.Security.Claims
@using Attendance.Domain.Utility
@{
    Layout = "~/Views/Shared/_LayoutLeave.cshtml";
}
<link href="~/css/daterangepicker.css" rel="stylesheet" />
<link href="~/css/leavetransaction.css" rel="stylesheet" />
<div class="main-inner container-fluid">

    <div class="col-12">
        <div class="page-title-box" style="margin-top:20px;">
            <h1 class="page-title">Leave Transaction</h1>
        </div>
    </div>
    <div class="col-12">
        <div class="card com-profile-info">
            <form class="form" id="userForm" method="post" asp-action="LeaveTransaction" asp-controller="LeaveTransaction" enctype="multipart/form-data">
                <input type="hidden" id="StartDate" name="StartDate" />
                <input type="hidden" id="EndDate" name="EndDate" />
                <div class="top-details">
                    <h2 class="page-form-title">Leave Transaction</h2>
                    <div class="">
                        <div class="item-input">
                            <label for="LeaveMasterId" class="form-label col-form-label required fw-semibold fs-6">Leave Type</label>
                            <select class="select2-custom form-control select2-hidden-accessible form-select" id="LeaveMasterId" name="LeaveMasterId" style="width:359.46px; height:48px;" required>
                                <option value="" disabled selected>Select Leave Type</option>
                                @foreach (var leave in ViewBag.leaveMasters)
                                {
                                    <option value="@leave.LeaveMasterId">@leave.LeaveType</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="">
                        <div class="item-input">
                            <label class="form-label col-form-label required fw-semibold fs-6">
                                <input type="checkbox" class="form-check-input" id="IsPaid" value="true" name="IsPaid"> &nbsp;
                                Is Paid
                            </label>
                        </div>
                    </div>
                    <div class="">
                        <div class="item-input">
                            <label class="form-label col-form-label required fw-semibold fs-6">Date</label>
                            <br />
                            <div id="reportrange" class="datepicker"
                                 style="background: #fff; cursor: pointer; padding: 10px 14px; border: 1px solid #ccc;
                height: 48px; display: inline-flex; align-items: center; white-space: nowrap;">
                                <i class="fa fa-calendar"></i>&nbsp;
                                <span style="margin-left: 10px;"></span>
                                <i class="fa fa-caret-down" style="margin-left: 10px;"></i>
                            </div>
                        </div>
                    </div>
                    <div class="">
                        <div class="item-input">
                            <label for="TotalDays" class="form-label col-form-label required fw-semibold fs-6">Total Days</label>
                            <input class="form-control userinput" type="number" id="TotalDays" name="TotalDays" style="width:359.46px; height:48px;" readonly>
                        </div>
                    </div>
                    <div class="">
                        <div class="item-input">
                            <label for="reason" class="form-label col-form-label required fw-semibold fs-6">Reason</label>
                            <textarea class="form-control userinput" id="reason" name="Reason" rows="3" placeholder="Enter reason for leave..." style="width:359.46px;" required></textarea>
                        </div>
                    </div>
                    <div class="col-xl-12 col-lg-6">
                        <div class="item-input">
                            <label class="form-label col-form-label required fw-semibold fs-6">
                                <input type="checkbox" class="form-check-input" id="Ishalfday" value="true" name="Ishalfday"> &nbsp;
                                Is HalfDay
                            </label>
                        </div>
                    </div>
                    <div class="">
                        <div class="item-input">
                            <label for="AddFile" class="form-label col-form-label fw-semibold fs-6">Add File</label>
                            <input type="file" accept=".pdf" id="AddFile" name="AddFile" class="form-control userinput" onchange="document.getElementById('AddFile').src = window.URL.createObjectURL(this.files[0])" placeholder="Upload file" style="width:359.46px;">
                        </div>
                    </div>
                </div>
                <div class="col-xl-6" style="margin-left:30px;">
                    @if (ViewBag.msg != null)
                    {
                        <div class="usermsg" id="temporaryMessage">
                            <span style="color:#00af00;font-weight:600;">@ViewBag.msg</span>
                        </div>
                    }
                    else
                    {
                        <div class="usermsg" id="temporaryMessage">
                            <span style="color:#d21313;font-weight:600;"> @ViewBag.errormsg</span>
                        </div>
                    }
                </div>
                <div class="button-main">
                    <button type="submit" class="btn btn-primary me-2" style="width:95px;height:38px;background-color: #0466c8;">Save</button>
                    @*<button type="submit" formaction="@Url.Action("MasterView", "MenuMaster")" class="btn btn-primary me-2" style="width:95px;height:38px;background-color: #0466c8;">View</button>*@
                    <a class="btn btn-primary me-2" href="/LeaveTransaction/LeaveTransactionView" style=" width: 95px;height: 38px;background-color: #0466c8;">View</a>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="~/js/leavetransaction.js"></script>
    <script src="~/js/moment.min.js"></script>
    <script src="~/js/daterangepicker.js"></script>
    <script src="~/js/msgtimeout.js"></script>

}