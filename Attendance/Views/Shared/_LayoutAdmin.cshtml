<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BTClock.UI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet">
    <!-- intl-tel-input CSS -->
    <link href="~/css/intlTelInput-largeFlags.css" rel="stylesheet" type="text/css" />
    <!-- Select2 CSS -->
    <link href="~/css/select2.min.css" rel="stylesheet" type="text/css" />
    <!-- Datatables css -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.css" rel="stylesheet">
    <!-- Select2 Bootstrap4 CSS -->
    <link href="~/css/select2-bootstrap4.min.css" rel="stylesheet" type="text/css" />
    <!-- Remixicon CSS -->
    <!-- SimpleBar CSS -->
    <link href="~/css/simplebar.css" rel="stylesheet" type="text/css" />
    <link href="~/css/datatables.bootstrap5.min.css" rel="stylesheet" />

    <!-- Bootstrap css -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <!-- App css -->
    <link href="~/css/remixicon.css" rel="stylesheet" type="text/css" />
    <link href="~/css/app-style.css" rel="stylesheet" type="text/css" />
    <link href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body data-sidenav-size="default" style="background: #F2F5F9;">
    <div class="wrapper">

        <div class="topbar container-fluid">
            <div class="d-flex align-items-center gap-lg-2 gap-1">
                <div class="logo-topbar">
                    <a href="#">
                        <span class="logo-sm" style="font-size:xx-large;color:#0466C8;">
                            <i class="fa-solid fa-clock" style="font-size:35px"></i>

                        </span>
                    </a>
                </div>
                <button class="button-toggle-menu">
                    <i class="ri-menu-line"></i>
                </button>
            </div>
        </div>

        <div class="leftside-menu">
            <div class="left-toplogo">
                <a href="#" class="logo logo-light">
                    <span class="logo-lg" style="font-size:xx-large;color:#0466C8;">
                        <i class="fa-regular fa-clock" style="font-size:35px"></i>

                        <b>BTClock</b>
                    </span>
                    <span class="logo-sm" style="font-size:xx-large;color:#0466C8;">
                        <i class="fa-solid fa-clock" style="font-size:35px"></i>

                    </span>
                </a>
                <button type="button" class="sidebar-toggle">
                    <i class="ri-arrow-left-double-line"></i>
                </button>
                <button type="button" class="sidebar-close-btn">
                    <i class="ri-close-line"></i>
                </button>
            </div>
            <div class="leftbar custom-scroll">
                <div class="left-sidebar-wrap">
                    <div class="sidebar-menu-area">
                        <!--- Sidemenu -->
                        <ul id="leftside-menu-container" class="side-nav" style="padding:initial;">
                            <li class="side-nav-item">
                                <a href="@ViewBag.appUrl/Employee/Employee" class="side-nav-link">
                                    <i class="ri-user-add-line"></i>
                                    <i class="ri-user-add-fill"></i>
                                    <span> Add Employee </span>
                                </a>
                            </li>
                            <li class="side-nav-item">
                                <a href="@ViewBag.appUrl/Master/MasterTable" class="side-nav-link">
                                    <i class="ri-brain-line"></i>
                                    <i class="ri-brain-fill"></i>
                                    <span> Master </span>
                                </a>
                            </li>

                            <li class="side-nav-item">
                                <a href="@ViewBag.appUrl/MenuMaster/MenuMaster" class="side-nav-link">
                                    <i class="ri-menu-line"></i>
                                    <i class="ri-menu-fill"></i>
                                    <span> Menu Master </span>
                                </a>
                            </li>
                            <li class="side-nav-item">
                                <a href="@ViewBag.appUrl/UserMenuMapping/UserMenuMapping" class="side-nav-link">
                                    <i class="ri-mastercard-line"></i>
                                    <i class="ri-mastercard-fill"></i>
                                    <span> UserMenuMapping </span>
                                </a>
                            </li>
                            <li class="side-nav-item">
                                <a href="@ViewBag.appUrl/LeaveTransaction/LeaveTransaction" class="side-nav-link">
                                    <i class="ri-calendar-2-line"></i>
                                    <i class="ri-calendar-2-fill"></i>
                                    <span> Leave Transaction </span>
                                </a>
                            </li>
                            <li class="side-nav-item">
                                <a href="@ViewBag.appUrl/LeaveBalance/LeaveBalance" class="side-nav-link">
                                    <i class="ri-calendar-event-line"></i>
                                    <i class="ri-calendar-event-fill"></i>
                                    <span> Leave Balance </span>
                                </a>
                            </li>
                            <li class="side-nav-item">
                                <a href="@ViewBag.appUrl/LeaveAssignment/LeaveAssignment" class="side-nav-link">
                                    <i class="ri-calendar-check-line"></i>
                                    <i class="ri-calendar-check-fill"></i>
                                    <span> Leave Assignment </span>
                                </a>
                            </li>
                            <li class="side-nav-item">
                                <a href="@ViewBag.appUrl/LeaveTransaction/LeaveApproval" class="side-nav-link">
                                    <i class="ri-calendar-check-line"></i>
                                    <i class="ri-calendar-check-fill"></i>
                                    <span> Leave Approval </span>
                                </a>
                            </li>
                            <li class="side-nav-item">
                                <a href="@ViewBag.appUrl/Permission/Permission" class="side-nav-link">
                                    <i class="ri-git-repository-private-line"></i>
                                    <i class="ri-git-repository-private-fill"></i>
                                    <span> Permission </span>
                                </a>
                            </li>
                        </ul>
                        <!--- End Sidemenu -->
                        <div class="clearfix"></div>
                    </div>
                </div>
            </div>
            <div class="left-footer">
                <ul class="side-nav">
                    <li class="side-nav-item">
                        <a href="@ViewBag.appUrl/Login/Login" class="side-nav-link">
                            <i class="ri-logout-circle-line"></i>
                            <span> Log out </span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
        <div class="content-page">
            <div class="content">
                @RenderBody()
            </div>
        </div>
    </div>
    <!-- Jquery Min JS -->
    <script src="~/js/jquery.min.js"></script>
    <!-- Bootstrap Bundle JS -->
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <!-- SimpleBar JS -->
    <script src="~/js/simplebar.min.js"></script>
    <!-- Select2 JS -->
    <script src="~/js/select2.min.js"></script>
    <!-- intl-tel-input JS -->
    <script src="~/js/intlTelInput.min.js"></script>
    <!-- Dropzone JS -->
    <script src="~/js/dropzone.min.js"></script>
    <!-- Repeater JS -->
    <script src="~/js/jquery.repeater.min.js"></script>
    <!-- Datatables js -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>
    <!-- Bootstrap & Popper (required for dropdowns) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"></script>

    <!-- Datatable Init js -->
    <script src="~/js/datatable-init.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.10.0/js/bootstrap-datepicker.min.js"> </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Script App JS -->
    <script src="~/js/msgtimeout.js"></script>
    <script src="~/js/script-app.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
