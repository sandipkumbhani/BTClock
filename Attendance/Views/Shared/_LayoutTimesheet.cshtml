@using Attendance.Domain.Models
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BTClock.UI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet">
    <!-- intl-tel-input CSS -->
    <link href="~/css/intlTelInput-largeFlags.css" rel="stylesheet" type="text/css" />
    <!-- Select2 CSS -->
    <link href="~/css/select2.min.css" rel="stylesheet" type="text/css" />
    <!-- Datatables css -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.css" rel="stylesheet">
    <!-- Select2 Bootstrap4 CSS -->
    <link href="~/css/select2-bootstrap4.min.css" rel="stylesheet" type="text/css" />
    <!-- Remixicon CSS -->
    <link href="~/css/remixicon.css" rel="stylesheet" type="text/css" />
    <!-- SimpleBar CSS -->
    <link href="~/css/simplebar.css" rel="stylesheet" type="text/css" />
    <!-- Bootstrap css -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <!-- App css -->
    <link href="~/css/app-style.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        /* Ensure the menu is visible */
        .leftside-menu {
            display: block !important;
            visibility: visible !important;
        }

        /* Adjust dropdown submenu visibility */
        .sidebar-submenu {
            display: none;
            padding-left: 20px;
        }

        /* Show submenu when clicked */
        .side-nav-item.dropdown.active .sidebar-submenu {
            display: block;
        }

        /* Ensure menu items are vertically stacked */
        .side-nav-item {
            list-style: none;
        }

            /* Style active menu item */
            .side-nav-item.active {
                background-color: #f0f0f0;
            }

        /* Add padding for menu items */
        .side-nav-link {
            padding: 10px 15px;
            display: block;
            text-decoration: none;
            color: #333;
        }

            /* Styling the hover effect */
            .side-nav-link:hover {
                background-color: #e0e0e0;
            }

    </style>
</head>
<body data-sidenav-size="default" style="background: #F2F5F9;">
    <div class="wrapper">
        @* <div class="navbar-custom">
			@if (ViewBag.Breadcrumbs != null)
			{
				@Html.Partial("_Breadcrumb", (IEnumerable<BreadcrumbItem>)ViewBag.Breadcrumbs)
			}
		</div> *@
        <div class="topbar container-fluid">
            <div class="d-flex align-items-center gap-lg-2 gap-1">
                <div class="logo-topbar">
                    <a href="#">
                        <span class="logo-sm" style="font-size:xx-large; color:#0466C8;">
                            <img src="~/images/BT.png" alt="BTClock Logo" style="height:35px;">
                        </span>
                    </a>
                </div>
                <button class="button-toggle-menu">
                    <i class="ri-menu-line"></i>
                </button>
            </div>
        </div>

        <div class="leftside-menu">
            <div class="left-toplogo">
                <a href="#" class="logo logo-light">
                    <span class="logo-lg" style="font-size:xx-large; color:#0466C8;">
                        <img src="~/images/BTClock.png" alt="BTClock Logo" style="height:60px;width:200px; vertical-align:middle; margin-right:8px;">
                    </span>

                    <span class="logo-sm" style="font-size:xx-large; color:#0466C8;">
                        <img src="~/images/BT.png" alt="BTClock Logo" style="height:35px;">
                    </span>
                </a>
                <button type="button" class="sidebar-toggle">
                    <i class="ri-arrow-left-double-line"></i>
                </button>
                <button type="button" class="sidebar-close-btn">
                    <i class="ri-close-line"></i>
                </button>
            </div>
            <div class="leftbar custom-scroll">
                <div class="left-sidebar-wrap">
                    <div class="sidebar-menu-area">
                        <!--- Sidemenu -->
                        <ul id="leftside-menu-container" class="side-nav">
                            @if (ViewBag.MainMenu != null)
                            {
                                @foreach (var item in ViewBag.MainMenu as List<MenuItemDto>)
                                {
                                    if (item.MenuMaster != null)  // Check if MenuMaster is not null
                                    {
                                        if (item.Children.Count() == 0)
                                        {
                                            <li class="side-nav-item">
                                                <a class="side-nav-link" href="@ViewBag.appUrl@item.MenuMaster.MenuPath">
                                                    <i class="@item.MenuMaster.Icon-line"></i>
                                                    <i class="@item.MenuMaster.Icon-fill"></i>
                                                    <span>@item.MenuMaster.Menuname</span>
                                                </a>
                                            </li>
                                        }
                                        else
                                        {
                                            <li class="side-nav-item dropdown">
                                                <a class="side-nav-link" href="javascript:void(0)">
                                                    <i class="@item.MenuMaster.Icon-line"></i>
                                                    <i class="@item.MenuMaster.Icon-fill"></i>
                                                    <span>@item.MenuMaster.Menuname</span>
                                                </a>
                                                @if (item.Children != null && item.Children.Any())
                                                {
                                                    <ul class="sidebar-submenu">
                                                        @foreach (var subItem in item.Children)
                                                        {
                                                            if (subItem.MenuMaster != null)
                                                            {
                                                                <li>
                                                                    <a href="@ViewBag.appUrl@subItem.MenuMaster.MenuPath">
                                                                        <span>@subItem.MenuMaster.Menuname</span>
                                                                    </a>
                                                                </li>
                                                            }
                                                        }
                                                    </ul>
                                                }
                                            </li>
                                        }
                                    }
                                }
                            }

                            <li class="side-nav-item">
                                <a href="@ViewBag.appUrl/Login/Logout" class="side-nav-link">
                                    <i class="ri-logout-circle-line"></i>
                                    <i class="ri-logout-circle-fill"></i>
                                    <span> Log out </span>
                                </a>
                            </li>
                        </ul>
                        <div class="clearfix"></div>
                    </div>
                </div>
            </div>
            <div class="left-footer">
                <ul class="side-nav">

                    <li class="side-nav-item">
                        <a href="@ViewBag.appUrl/Dashboard/Dashboard" class="side-nav-link">
                            <i class="ri-home-4-line"></i>
                            <span>Back To Home </span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
        <div class="content-page">
            <div class="content">
                @RenderBody()
            </div>
        </div>
    </div>
    <!-- Jquery Min JS -->
    <script src="~/js/jquery.min.js"></script>
    <!-- Bootstrap Bundle JS -->
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <!-- SimpleBar JS -->
    <script src="~/js/simplebar.min.js"></script>
    <!-- Select2 JS -->
    <script src="~/js/select2.min.js"></script>
    <!-- intl-tel-input JS -->
    <script src="~/js/intlTelInput.min.js"></script>
    <!-- Dropzone JS -->
    <script src="~/js/dropzone.min.js"></script>
    <!-- Repeater JS -->
    <script src="~/js/jquery.repeater.min.js"></script>
    <!-- Datatables js -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>
    <!-- Bootstrap & Popper (required for dropdowns) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"></script>

    <!-- Datatable Init js -->
    <script src="~/js/datatable-init.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.10.0/js/bootstrap-datepicker.min.js"> </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
                $(document).ready(function () {
            // Handle dropdown toggle
            $('.side-nav-item.dropdown').on('click', function () {
                $(this).toggleClass('active');
            });
        });

    </script>
    <!-- Script App JS -->
    <script src="~/js/script-app.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>