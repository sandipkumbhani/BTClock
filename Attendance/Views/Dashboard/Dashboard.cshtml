<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />



<div class="content-page" style="margin:90px 0 40px 0">
    <div class="content">
        <div class="main-inner container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="card com-profile-info">
						<div class="modal fade" id="settingsModal" tabindex="-1">
							<div class="modal-dialog">
								<div class="modal-content">
								</div>
							</div>
						</div>
						<div class="time-tracker" style="max-width:888px;margin:auto;text-align:center;margin-bottom:30px;">
							<h4 style="color:#0466c8;font-weight:600; margin-top:40px;">Work Time Tracker</h4>
							<div style="margin-top:20px;">
								<button id="clockInBtn" class="btn btn-success" style="margin-right:10px;">Clock In</button>
								<button id="clockOutBtn" class="btn btn-danger">Clock Out</button>
							</div>
							<span id="error-message" style="color: red; display: none;"></span>
							<div style="margin:20px 0;">
								<span id="startTime" style="font-weight:600;"></span>
								<span id="endTime" style="font-weight:600;"></span>
							</div>
							<div>
								<span id="workDuration" style="font-size:1.2em;color:#0466c8;font-weight:600;"></span>
							</div>
							<div id="liveCounter" style="margin-top:18px;font-size:1.1em;color:#0466c8;font-weight:600;"></div>
							<div style="margin-top:30px;">
								<h5 style="color:#0466c8;font-weight:600; padding-bottom:15px;">Last Attendance Records</h5>
								<table class="table table-bordered table-sm" style="background:#fff;max-width:100%;margin:auto; width:800px;">
									<thead style="background:#e8f5e9;">
										<tr>
											<th>Date</th>
											<th>Clock In</th>
											<th>Clock Out</th>
											<th>Total Time</th>
										</tr>
									</thead>
									<tbody id="attendanceTableBody">
										<!-- Records will be inserted here -->
									</tbody>
								</table>
							</div>
						</div>
					</div>
                </div>
            </div>
        </div>
    </div>
</div>
		
		

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<link href="~/css/dashboard.css" rel="stylesheet" />
	<script src="~/js/Dashboard.js"></script>


