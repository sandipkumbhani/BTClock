						<!-- Leave Tab -->
						<div class="tab-pane fade @(openPanel=="leave" ? "show active" : "")" id="tab-leave" role="tabpanel">
							<form method="post" action="@Url.Action("Leave","Master")">
								<div class="mb-3" style="margin-left:15px;">
									<input type="hidden" id="LeaveMasterId" name="Id" />
									<label for="LeaveType" class="form-label">Leave Type</label>
									<input id="LeaveType" name="LeaveType" class="form-control" required placeholder="Enter Leave Type" style="width:370px;">
