						<!-- Holiday Tab -->
						<div class="tab-pane fade @(openPanel=="Holiday" ? "show active" : "")" id="tab-Holiday" role="tabpanel">
							<form method="post" action="@Url.Action("Holiday","Master")">
								<div class="mb-3" style="margin-left:15px;">
									<input type="hidden" id="HolidayMasterId" name="Id" />
									<div class="item-input">

										<label for="HolidayDate" class="form-label">Holiday Date</label>
										<input type="text" data-provide="datepicker" class="form-control userinput date" id="datepicker" name="HolidayDate" placeholder="Select a Date" style="width:370px;	">
									</div>
									<div class="item-input">

										<label for="HolidayDescription" class="form-label">Holiday Description</label>
