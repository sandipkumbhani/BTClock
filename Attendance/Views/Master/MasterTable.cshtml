@section Scripts {
	<script>
		var openPanel = "@openPanel";
		var openView  = "@openView";
		var editUrl = '@Url.Action("EditModule", "Master")' + '?id=';
		var deleteurl ='@Url.Action("DeleteModule", "Master")' + '?id=';
		var editDeptUrl = '@Url.Action("EditDepartment", "Master")' + '?id=';
		var deleteDeptUrl ='@Url.Action("DeleteDept", "Master")' + '?id=';
		var editdesignationUrl ='@Url.Action("EditDesignation", "Master")' + '?id=';
		var deletedesignationUrl ='@Url.Action("DeleteDesig", "Master")' + '?id=';
		var editleavemasterUrl = '@Url.Action("EditLeave", "Master")' + '?id=';
