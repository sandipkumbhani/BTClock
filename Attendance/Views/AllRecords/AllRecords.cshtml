@using Attendance.Domain.Models
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<!-- DataTables CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<link href="~/css/record.css" rel="stylesheet" />
<link href="~/css/daterangepicker.css" rel="stylesheet" />
<div class="content-page" style="margin:35px 0 0 0">
    <div class="content">
        <div class="main-inner container-fluid">

            <div class="row">
                <div class="col-4 mb-3" id="employee-container" style="width:auto;">
                    <!-- Employee Dropdown -->
                    <div class="item-input mb-2">
                        <label for="EmployeeId" class="form-label required fw-semibold fs-6">Employee</label>
                        <select class="select2-custom form-control form-select"
                                id="EmployeeId"
                                name="EmployeeId"
                                style="width: 100%;">
                            <!-- width will be controlled by parent -->
                            <option value="">All Employees</option>
                            @foreach (var employee in ViewBag.EmployeeList)
                            {
                                <option value="@employee.EmployeeId">@employee.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Datepicker -->
                    <div class="datepicker" id="reportrange"
                         style="background: #fff; cursor: pointer; padding: 5px 10px; border: 1px solid #ccc; height: 48px; align-content:center; display:inline-block; width: fit-content;">
                        <i class="fa fa-calendar"></i>&nbsp;
                        <span></span>
                        <i class="fa fa-caret-down" style="margin-left:16px;"></i>
                    </div>
                </div>

                <!-- Month Filter Dropdown (styled exactly like screenshot) -->
                @* <div class="col-12 mb-3">
                    <div class="dropdown">
                        <button id="filterDropdown"
                                class="btn btn-outline-secondary dropdown-toggle month-filter"
                                data-bs-toggle="dropdown" aria-expanded="false">
                            -- All Months -- <i class="ri-arrow-down-s-fill" style="font-size:larger"></i>
                        </button>
                        <ul class="dropdown-menu" id="monthDropdownMenu" aria-labelledby="filterDropdown"></ul>
                    </div>
                </div> *@
                <div class="col-12">
                    <div class="card com-profile-info">
                        <!-- Top Header -->
                        <div class="table-top-header">
                            <h3>Records</h3>
                            <div class="d-flex gap-2">
                                <div class="table-search-box">
                                    <input type="text" id="customFranchiseSearch" class="form-control form-control-sm" placeholder="Search...">
                                    <button type="submit"><i class="ri-search-line"></i></button>
                                </div>
                                <div id="exportFranchiseButtons">
                                    <button id="exportExcel" class="btn-btn-outline-secondary">
                                        <i class="bi bi-file-earmark-excel"></i> Export
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-6" style="margin-left:30px;">
                            @if (TempData["msg"] != null)
                            {
                                <div class="usermsg" id="temporaryMessage">
                                    <span style="color:#00af00;font-weight:600;">@TempData["msg"]</span>
                                </div>
                            }
                            else
                            {
                                <div class="usermsg" id="temporaryMessage">
                                    <span style="color:#d21313;font-weight:600;"> @TempData["errormsg"]</span>
                                </div>
                            }
                        </div>
                        <!-- Table -->
                        <div class="table-responsive">
                            <table id="franchiseTable" class="table dt-responsive nowrap">
                                <thead>
                                    <tr>
                                        <th>Employee Name</th>
                                        <th>Date</th>
                                        <th>Clock In</th>
                                        <th>Clock Out</th>
                                        <th>Total Hours</th>
                                        <th>Overtime Hours</th>
                                        <th>Actions</th>

                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                            <div id="dataLoader" class=" justify-content-center" style="display:none; margin-left: 598px;">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                            <!-- Bottom Area -->
                            <div class="datatable-footer-bottom">
                                <div class="totle-left">
                                    <span id="totalList">Total List: <span id="recordCount">0</span></span>
                                </div>
                                <div id="customFranchisePagination" class="dataTables_paginate paging_simple_numbers"></div>
                                <div class="show-page">
                                    <span>Show per page:</span>
                                    <select id="pageLength" class="form-select"></select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts
{
    <script type="text/javascript">
        var url = '@Url.Action("UpdateAttendanceRecord", "EditAttendanceRecord")' + '?id=';
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="~/js/moment.min.js"></script>
    <script src="~/js/daterangepicker.js"></script>
    <script src="~/js/allRecords.js"></script>
    <script src="~/js/msgtimeout.js"></script>
}

