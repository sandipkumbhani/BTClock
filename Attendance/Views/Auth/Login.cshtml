@model Attendance.Api.Contracts.Request.UserLoginDto
@{
    ViewData["Title"] = "Login";
}
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<style>
body {
    margin: 0;
    padding: 0;
    font-family: 'Poppins', sans-serif;
    min-height: 100vh;
    width: 100vw;
    background: url('../images/login-bg (1).png') no-repeat center center fixed;
    position: relative;
}
.login-wrapper {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: rgba(0, 0, 0, 0.3);
    width: 100vw;
}
.card-login {
    background: rgba(255, 255, 255, 0.2);
    padding: 40px 30px;
    width: 100%;
    max-width: 400px;
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
    position: relative;
    z-index: 1;
}
.card-login h2 {
    color: #fff;
    font-weight: 600;
    text-align: center;
    margin-bottom: 20px;
    font-size: 2em;
}
.form-label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #ddd;
    font-size: 0.95em;
}
.form-control {
    width: 100%;
    padding: 14px 20px;
    border-radius: 25px;
    border: none;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    font-size: 1em;
    transition: all 0.3s ease;
}
.form-control:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.2);
    box-shadow: 0 0 15px rgba(255, 255, 255, 0.4);
}
.btn-login {
    width: 100%;
    padding: 14px;
    border-radius: 25px;
    border: none;
    background: linear-gradient(135deg, #4caf50 0%, #8bc34a 100%);
    color: #fff;
    font-weight: 600;
    font-size: 1.1em;
    cursor: pointer;
    transition: all 0.3s ease;
}
.btn-login:hover {
    background: linear-gradient(135deg, #8bc34a 0%, #4caf50 100%);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
    transform: translateY(-2px);
}
.login-link {
    margin-top: 15px;
    text-align: center;
    font-size: 0.95em;
    color: #ddd;
}
.login-link a {
    color: #fff;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.3s ease;
}
.login-link a:hover {
    color: #6a11cb;
}
</style>

<div class="login-wrapper">
    <div class="card-login">
        
        <h2>Employee Login</h2>
       
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }
        @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="validation-summary-errors">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                <label class="form-label" for="Email"> Email Address</label>
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Enter your email", type = "email", autocomplete = "username" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                <label class="form-label" for="Password"> Password</label>
                <div style="position: relative;">
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Password", autocomplete = "current-password", id = "Password", style = "padding-right: 44px;" })
                    <button type="button" id="togglePassword" tabindex="-1" style="position: absolute; top: 50%; right: 10px; transform: translateY(-50%); border: none; background: transparent; padding: 0; margin: 0; height: 32px; width: 32px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-eye" style="font-size: 1.25em; color: #888;"></i>
                    </button>
                </div>
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-login"><i class="bi bi-box-arrow-in-right"></i> Login</button>
            </div>
            <div class="login-link mt-3">
                New user? <a href="@Url.Action("URegister", "Register")">Register here</a>
            </div>
        }
        
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {
    function setupPasswordToggle(toggleId, inputId) {
        const toggle = document.getElementById(toggleId);
        const input = document.getElementById(inputId);
        const icon = toggle.querySelector('i');
        toggle.addEventListener('click', () => {
            const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
            input.setAttribute('type', type);
            icon.className = type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
        });
    }
    setupPasswordToggle('togglePassword', 'Password');
});
</script>
