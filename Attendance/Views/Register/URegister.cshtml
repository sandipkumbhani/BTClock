@model Attendance.Api.Contracts.Request.UserRegisterDto
@{
    ViewData["Title"] = "Register";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<style >
    body {
        margin: 0;
        padding: 0;
        font-family: 'Poppins', sans-serif;
        min-height: 100vh;
        width: 100vw;
        background: url('/images/login-bg (1).png') no-repeat center center fixed;
        background-size: cover;
        position: relative;
    }

    .login-wrapper {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: rgba(0, 0, 0, 0.2);
        width: 100vw;
    }

    .card-login {
        background: rgba(255, 255, 255, 0.1);
        padding: 40px 30px;
        width: 100%;
        max-width: 400px;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        transition: all 0.3s ease;
        position: relative;
        z-index: 1;
    }

        .card-login h2 {
            color: #fff;
            font-weight: 600;
            text-align: center;
            margin-bottom: 20px;
            font-size: 2em;
        }



    .form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #ddd;
        font-size: 0.95em;
    }

    .form-control {
        width: 100%;
        padding: 14px 20px;
        border-radius: 25px;
        border: none;
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        font-size: 1em;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            outline: none;
            background: rgba(255, 255, 255, 0.2);
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.4);
        }

    .btn-login {
        width: 100%;
        padding: 14px;
        border-radius: 25px;
        border: none;
        background: linear-gradient(135deg, #4caf50 0%, #8bc34a 100%);
        color: #fff;
        font-weight: 600;
        font-size: 1.1em;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-login:hover {
            background: linear-gradient(135deg, #8bc34a 0%, #4caf50 100%);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            transform: translateY(-2px);
        }

    .login-link {
        margin-top: 15px;
        text-align: center;
        font-size: 0.95em;
        color: #ddd;
    }

        .login-link a {
            color: #fff;
            font-weight: 600;
            text-decoration: none;
            transition: color 0.3s ease;
        }

            .login-link a:hover {
                color: #6a11cb;
            }

    .btn-outline-secondary#togglePassword,
    .btn-outline-secondary#toggleConfirmPassword {
        border: none !important;
        background-color: transparent !important;
        box-shadow: none !important;
        outline: none !important;
    }

    .input-group > .form-control {
        border-top-right-radius: 25px !important;
        border-bottom-right-radius: 25px !important;
    }

    .input-group > .btn {
        border-top-left-radius: 0 !important;
        border-bottom-left-radius: 0 !important;
    }
</style>

<div class="login-wrapper" >
    <div class="card-login">
        
        <h2>Register</h2>
       @*  <div style="text-align:center; color:#bbb; margin-bottom: 18px; font-size:1.05em;">
            Register to access the Employee Attendance System
        </div> *@
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @using (Html.BeginForm("Register", "Register", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="validation-summary-errors">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                <label class="form-label" for="Email"> Email Address</label>
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Enter your company email", type = "email", autocomplete = "username" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                <label class="form-label" for="Password">Password</label>
                <div style="position: relative;">
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Password", autocomplete = "new-password", id = "Password", style = "padding-right: 44px;" })
                    <button type="button" id="togglePassword" tabindex="-1" style="position: absolute; top: 50%; right: 10px; transform: translateY(-50%); border: none; background: transparent; padding: 0; margin: 0; height: 32px; width: 32px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-eye" style="font-size: 1.25em; color: #888;"></i>
                    </button>
                </div>
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                <label class="form-label" for="ConfirmPassword"> Confirm Password</label>
                <div style="position: relative;">
                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Confirm password", autocomplete = "new-password", id = "ConfirmPassword", style = "padding-right: 44px;" })
                    <button type="button" id="toggleConfirmPassword" tabindex="-1" style="position: absolute; top: 50%; right: 10px; transform: translateY(-50%); border: none; background: transparent; padding: 0; margin: 0; height: 32px; width: 32px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-eye" style="font-size: 1.25em; color: #888;"></i>
                    </button>
                </div>
                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
                <span class="text-danger" id="confirmPasswordError"></span>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-login" onclick="return validateConfirmPassword();"><i class="bi bi-person-plus"></i> Register</button>
            </div>
            <div class="login-link mt-3">
                Already registered? <a href="@Url.Action("Login", "Auth")">Login </a>
            </div>
        }
       
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
function validateConfirmPassword() {
    var password = document.getElementById('Password').value;
    var confirmPassword = document.getElementById('ConfirmPassword').value;
    var errorSpan = document.getElementById('confirmPasswordError');
    if (password !== confirmPassword) {
        errorSpan.textContent = 'Passwords do not match.';
        return false;
    } else {
        errorSpan.textContent = '';
        return true;
    }
}
document.addEventListener("DOMContentLoaded", function () {
    function setupPasswordToggle(toggleId, inputId) {
        const toggle = document.getElementById(toggleId);
        const input = document.getElementById(inputId);
        const icon = toggle.querySelector('i');
        toggle.addEventListener('click', () => {
            const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
            input.setAttribute('type', type);
            icon.className = type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
        });
    }
    setupPasswordToggle('togglePassword', 'Password');
    setupPasswordToggle('toggleConfirmPassword', 'ConfirmPassword');
});
</script>
